{
  "name": "det-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node server/postgres-app.js",
    "dev": "vite --host 0.0.0.0",
    "api": "node server.js",
    "api:pg": "node server/postgres-app.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test test/unit/*.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:docker": "bash test/run-docker-e2e.sh"
  },
  "dependencies": {
    "sharp": "0.35.2",
    "pg": "8.22.0",
    "minio": "8.0.7",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "lucide-react": "1.21.0",
    "typescript": "6.0.3"
  }
}

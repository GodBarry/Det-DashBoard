# Copy to .env.portable to override portable Docker defaults.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=5173
# For a registry release, set APP_IMAGE and BUILD_LOCAL_IMAGE=false.
APP_IMAGE=det-dashboard:local
BUILD_LOCAL_IMAGE=true
DB_BIND_ADDRESS=127.0.0.1
DB_PORT=55432
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_HOST_PORT=59000
MINIO_CONSOLE_BIND_ADDRESS=127.0.0.1
MINIO_CONSOLE_HOST_PORT=59001

POSTGRES_DB=det_dashboard
POSTGRES_USER=det
POSTGRES_PASSWORD=change-this-password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-password
MINIO_BUCKET=zbh-datasets

# Imported objects are copied to MinIO by default for portable durability.
# Set true only for a local linked-data deployment that deliberately keeps
# source files in place and accepts broken links if those files move.
OBJECT_STORE_WRITE_FALLBACK=false

# The packaged app is local-only by default. Mount scope can be narrowed here.
HOST_BROWSE_ROOT=/
BROWSE_ROOT_DISPLAY=/
EXPORTS_DIR=./exports
EXPORT_ROOT_DISPLAY=./exports

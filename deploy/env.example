APP_IMAGE=det-dashboard:release
POSTGRES_IMAGE=det-dashboard-postgres:16
MINIO_IMAGE=det-dashboard-minio:2025-09-07
COMPOSE_PROJECT_NAME=det-dashboard

APP_BIND_ADDRESS=127.0.0.1
APP_PORT=5173
POSTGRES_DB=det_dashboard
POSTGRES_USER=det
POSTGRES_PASSWORD=GENERATE_ON_FIRST_START
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=GENERATE_ON_FIRST_START
MINIO_BUCKET=det-dashboard
HOST_DIALOG_TOKEN=GENERATE_ON_FIRST_START
HOST_DIALOG_URL=
NATIVE_DIALOG_MODE=disabled

# start.sh replaces these defaults with absolute paths on first launch.
HOST_BROWSE_ROOT=/home
DATASETS_DIR=./datasets
EXPORTS_DIR=./exports
APP_STORAGE_DIR=./portable-data/storage
POSTGRES_DATA_DIR=./portable-data/postgres
MINIO_DATA_DIR=./portable-data/minio
HOST_MODEL_ROOT=./runtime-assets/models
HOST_PYTHON_ROOT=./runtime-assets/python-envs

ENABLE_GPU=false
FORCE_OFFLINE_IMAGE_LOAD=false
NVIDIA_VISIBLE_DEVICES=all
TRAINING_WORKER_ENABLED=false
INFERENCE_WORKER_ENABLED=true

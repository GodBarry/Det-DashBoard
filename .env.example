# Copy this file to det-dashboard.env for local development.
# Keep this example generic; put machine-specific paths in det-dashboard.env.

PORT=4177

# Dataset source root. The app only imports files from paths under this root.
DATA_ROOT=./runtime/data-root

# Local cache root for runtime files, exports, object-store fallback, model copies,
# and unpacked Python environments. MinIO remains the source of truth for assets.
STORAGE_ROOT=./runtime/cache

# PostgreSQL connection used by the Node API.
DATABASE_URL=postgres://det:det_password@localhost:5432/det_dashboard

# MinIO object storage used as the formal asset store.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zbh-datasets

# Docker container names used by restart scripts.
POSTGRES_CONTAINER=det-dashboard-postgres
MINIO_CONTAINER=det-dashboard-minio

# Docker data directories. Docker Compose reads these from .env.
POSTGRES_DATA_DIR=./runtime/postgres
MINIO_DATA_DIR=./runtime/minio

# Windows example:
# DATA_ROOT=F:\ZBH
# STORAGE_ROOT=F:\ZBH\zhuji\runtime\cache
# POSTGRES_DATA_DIR=./runtime/postgres
# MINIO_DATA_DIR=./runtime/minio

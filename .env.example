# DATA_ROOT=F:\ZBH
# STORAGE_ROOT=F:\ZBH\zhuji
# POSTGRES_DATA_DIR=./runtime/postgres
# MINIO_DATA_DIR=F:/ZBH/zhuji/runtime/minio

# Local PG17 development database:
DATABASE_URL=postgres://det:det_password@127.0.0.1:55434/det_dashboard
# Docker real-data PostgreSQL 16 database:
# DATABASE_URL=postgres://det:det_password@127.0.0.1:55432/det_dashboard

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zbh-datasets

PORT=4177

# Linux/macOS default examples
DATA_ROOT=./runtime/data-root
STORAGE_ROOT=./runtime
POSTGRES_DATA_DIR=./runtime/postgres
MINIO_DATA_DIR=./runtime/minio
POSTGRES_REAL_PORT=55432
MINIO_REAL_PORT=9000
MINIO_REAL_CONSOLE_PORT=9001
LOCAL_UID=1000
LOCAL_GID=1000

